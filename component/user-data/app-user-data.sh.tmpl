#!/usr/bin/env bash
set -euo pipefail

exec > >(tee -a /var/log/user-data.log) 2>&1

SERVICE_NAME="${service_name}"

APP_DIR="/home/ubuntu/app"
APP_JAR_PATH="$APP_DIR/app.jar"
NOHUP_LOG="$APP_DIR/app.log"

if command -v dnf >/dev/null 2>&1; then
  dnf -y install java-17-amazon-corretto-headless
elif command -v yum >/dev/null 2>&1; then
  yum -y install java-17-amazon-corretto-headless
elif command -v apt-get >/dev/null 2>&1; then
  apt-get update -y
  apt-get install -y openjdk-17-jre-headless
fi

if [ ! -f "$APP_JAR_PATH" ]; then
  echo "missing app jar: $APP_JAR_PATH"
  exit 1
fi

mkdir -p /usr/local/bin
cat >/usr/local/bin/start-${service_name}.sh <<STARTSCRIPT
#!/usr/bin/env bash
set -euo pipefail
cd $APP_DIR
pkill -f 'java .*app.jar' || true
nohup java -Xms1024m -Xmx1024m -XX:+UseG1GC -XX:MaxMetaspaceSize=256m -jar app.jar --spring.profiles.active=dev >> $NOHUP_LOG 2>&1 &
STARTSCRIPT
chmod 755 /usr/local/bin/start-${service_name}.sh

cat >/etc/systemd/system/${service_name}.service <<SERVICE
[Unit]
Description=${service_name} nohup launcher
After=network.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/start-${service_name}.sh

[Install]
WantedBy=multi-user.target
SERVICE

systemctl daemon-reload
systemctl enable ${service_name}.service
systemctl restart ${service_name}.service
